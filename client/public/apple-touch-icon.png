<svg width="180" height="180" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background with gradient -->
  <circle cx="16" cy="16" r="16" fill="url(#gradient)"/>
  
  <!-- Complex neural network pattern -->
  <g transform="translate(16, 16)">
    <!-- Central processing core -->
    <circle cx="0" cy="0" r="3" fill="white" opacity="0.95"/>
    <circle cx="0" cy="0" r="1.5" fill="url(#gradient)"/>
    
    <!-- Primary neural nodes -->
    <circle cx="-6" cy="-6" r="2" fill="white" opacity="0.9"/>
    <circle cx="6" cy="-6" r="2" fill="white" opacity="0.9"/>
    <circle cx="-6" cy="6" r="2" fill="white" opacity="0.9"/>
    <circle cx="6" cy="6" r="2" fill="white" opacity="0.9"/>
    <circle cx="0" cy="-8" r="2" fill="white" opacity="0.9"/>
    <circle cx="0" cy="8" r="2" fill="white" opacity="0.9"/>
    <circle cx="-8" cy="0" r="2" fill="white" opacity="0.9"/>
    <circle cx="8" cy="0" r="2" fill="white" opacity="0.9"/>
    
    <!-- Secondary neural nodes -->
    <circle cx="-10" cy="-10" r="1" fill="white" opacity="0.7"/>
    <circle cx="10" cy="-10" r="1" fill="white" opacity="0.7"/>
    <circle cx="-10" cy="10" r="1" fill="white" opacity="0.7"/>
    <circle cx="10" cy="10" r="1" fill="white" opacity="0.7"/>
    
    <!-- Neural connections - primary -->
    <line x1="0" y1="0" x2="-6" y2="-6" stroke="white" stroke-width="1.5" opacity="0.6"/>
    <line x1="0" y1="0" x2="6" y2="-6" stroke="white" stroke-width="1.5" opacity="0.6"/>
    <line x1="0" y1="0" x2="-6" y2="6" stroke="white" stroke-width="1.5" opacity="0.6"/>
    <line x1="0" y1="0" x2="6" y2="6" stroke="white" stroke-width="1.5" opacity="0.6"/>
    <line x1="0" y1="0" x2="0" y2="-8" stroke="white" stroke-width="1.5" opacity="0.6"/>
    <line x1="0" y1="0" x2="0" y2="8" stroke="white" stroke-width="1.5" opacity="0.6"/>
    <line x1="0" y1="0" x2="-8" y2="0" stroke="white" stroke-width="1.5" opacity="0.6"/>
    <line x1="0" y1="0" x2="8" y2="0" stroke="white" stroke-width="1.5" opacity="0.6"/>
    
    <!-- Neural connections - secondary -->
    <line x1="-6" y1="-6" x2="-10" y2="-10" stroke="white" stroke-width="1" opacity="0.4"/>
    <line x1="6" y1="-6" x2="10" y2="-10" stroke="white" stroke-width="1" opacity="0.4"/>
    <line x1="-6" y1="6" x2="-10" y2="10" stroke="white" stroke-width="1" opacity="0.4"/>
    <line x1="6" y1="6" x2="10" y2="10" stroke="white" stroke-width="1" opacity="0.4"/>
    
    <!-- Cross connections for complexity -->
    <line x1="-6" y1="-6" x2="6" y2="-6" stroke="white" stroke-width="0.8" opacity="0.3"/>
    <line x1="-6" y1="6" x2="6" y2="6" stroke="white" stroke-width="0.8" opacity="0.3"/>
    <line x1="-8" y1="0" x2="0" y2="-8" stroke="white" stroke-width="0.8" opacity="0.3"/>
    <line x1="8" y1="0" x2="0" y2="-8" stroke="white" stroke-width="0.8" opacity="0.3"/>
    
    <!-- Synaptic activity indicators -->
    <circle cx="-3" cy="-3" r="0.5" fill="white" opacity="0.8"/>
    <circle cx="3" cy="-3" r="0.5" fill="white" opacity="0.8"/>
    <circle cx="-3" cy="3" r="0.5" fill="white" opacity="0.8"/>
    <circle cx="3" cy="3" r="0.5" fill="white" opacity="0.8"/>
  </g>
  
  <!-- Gradient definition -->
  <defs>
    <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3B82F6"/>
      <stop offset="100%" style="stop-color:#8B5CF6"/>
    </linearGradient>
  </defs>
</svg>
